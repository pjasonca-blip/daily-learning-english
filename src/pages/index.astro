---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
---

<Layout>
  <header class="py-10">
      <h1 class="text-4xl font-extrabold tracking-tight">My learning journal 📚</h1>
      <p class="mt-2 text-slate-600">Creating blog with Astro 5.0</p>
  </header>

  <ul class="grid gap-6">
      {posts.map(post => (
          <li class="group border p-6 rounded-2xl bg-white hover:border-indigo-500 transition-colors shadow-sm">
              <a href={`/blog/${post.id}`}>
                  <h2 class="text-2xl font-bold group-hover:text-indigo-600">{post.data.title}</h2>
                  <p class="text-slate-500 mt-2 line-clamp-2">{post.data.description}</p>
                  <div class="mt-4 text-sm text-slate-400">
                      {post.data.date.toLocaleDateString()}
                  </div>
              </a>
          </li>
      ))}
  </ul>
</Layout>