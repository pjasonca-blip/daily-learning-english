---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// 1. Astro에게 어떤 페이지들을 미리 만들지 알려줍니다.
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id }, // 주소창에 쓰일 id (예: first-post)
    props: { post },         // 해당 페이지에 넘겨줄 데이터
  }));
}

// 2. 위에서 넘겨준 props를 받습니다.
const { post } = Astro.props;
// 3. 마크다운 본문을 렌더링합니다.
const { Content } = await render(post);
---

<Layout title={post.data.title}>
    <article class="prose prose-slate dark:prose-invert lg:prose-xl mx-auto py-12">
        <header class="mb-8 border-b border-border-base pb-8">
            <h1 class="text-4xl font-bold mb-4 text-text-base">{post.data.title}</h1>
            <div class="flex gap-4 text-text-muted text-sm">
                <time>Posted: {post.data.date.toLocaleDateString()}</time>
                <span>•</span>
                <span>Study Notes</span>
            </div>
        </header>

        {/* 마크다운 본문이 들어가는 자리 */}
        <div class="content-body text-text-base">
            <Content />
        </div>

        <footer class="mt-12 pt-8 border-t border-border-base">
            <a href="/" class="text-indigo-600 hover:underline">← Back to List</a>
        </footer>
    </article>
</Layout>