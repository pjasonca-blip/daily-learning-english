<button id="themeToggle" class="p-2 rounded-lg bg-bg-toggle hover:ring-2 ring-indigo-400 transition-all">
    <span class="dark:hidden">🌙</span>
    <span class="hidden dark:inline">☀️</span>
</button>

<script is:inline>
    // 이 함수를 전역(window)에 등록하거나 버튼에 직접 연결합니다.
    function setupTheme() {
        const button = document.getElementById('themeToggle');
        if (!button) return; // 버튼을 못 찾으면 종료

        button.addEventListener('click', () => {
        const element = document.documentElement;
        element.classList.toggle("dark");
        
        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
        console.log("현재 다크모드 여부:", isDark); // 확인용 로그
        });
    }

    // 페이지 로드 시 실행
    setupTheme();
</script>