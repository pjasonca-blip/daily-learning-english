---
import '../styles/global.css';
import heroImage from '../assets/images/heroImage.jpg';
// ThemeToggle 임포트 삭제
const {title} = Astro.props;
---
<!-- 아이콘(UI) -->
<script type="module" src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.esm.js"></script>
<script nomodule src="https://unpkg.com/ionicons@7.1.0/dist/ionicons/ionicons.js"></script>

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" initial-scale=1.0/>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title || 'Daily Learning English'}</title>
        </head>
    <body class="bg-white text-slate-900 min-h-screen">
        <div class="navbar bg-bg-nav shadow-sm">
            <div class="max-w-9/10 mx-auto w-full flex justify-between items-center">
                <div class="flex-1">
                    <a href="/" class="btn btn-ghost text-xl">Daily Learning English</a>
                </div>
    
                <!-- mobile Navbar -->
                <div class="flex-none">
                    <div class="dropdown dropdown-end">
                        <div class="lg:hidden md:hidden">
                            <div tabindex="0" role="button" class="btn btn-ghost md:hidden">
                                <ion-icon name="menu-outline"></ion-icon>
                            </div>
                            <ul tabindex="-1" class="menu menu-sm dropdown-content mt-3 p-2 shadow bg-base-100 rounded-box w-52">
                                <li><a href="/" class="hover:text-indigo-600 transition-colors">Home</a></li>
                                <li><a href="/every-week-voca" class="hover:text-indigo-600 transition-colors">Every Week Voca</a></li>
                                <li><a href="/my-english-journey" class="hover:text-indigo-600 transition-colors">My English Journey</a></li>
                                <li><a href="/about" class="hover:text-indigo-600 transition-colors">About</a></li>
                                <li><a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                
    
                <!-- Desktop Navbar -->
                <div class="hidden md:flex">
                    <ul class="menu menu-horizontal px-1">
                        <li><a href="/" class="hover:text-indigo-600 transition-colors">Home</a></li>
                        <li><a href="/my-english-journey" class="hover:text-indigo-600 transition-colors">My English Journey</a></li>
                        <li><a href="/every-week-voca" class="hover:text-indigo-600 transition-colors">Every Week Voca</a></li>
                        <li><a href="/about" class="hover:text-indigo-600 transition-colors">About</a></li>
                        <li><a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Hero -->
        <div
            class="hero h-[50vh] min-h-[300px] max-w-9/10 mx-auto p-3 mt-5 relative overflow-hidden rounded-2xl"
            style={`background-image: url(${heroImage.src});`}
        >
            <div class="hero-overlay"></div>
            <div class="hero-content text-neutral-content text-center">
                <div class="max-w-md">
                <h1 class="mb-5 text-5xl font-bold">Learn English Daily</h1>
                <p class="mb-5">
                    This website is dedicated to helping you improve your English skills with daily vocabulary, grammar tips, and engaging content. Whether you're a beginner or looking to refine your skills, we've got you covered!
                </p>
                <button class="btn btn-primary">Get Started</button>
                </div>
            </div>
        </div>

        <!-- Category Cards Section -->
        <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16 max-w-9/10 mx-auto mt-10">
            <!-- Card 1: Every Week Voca -->
            <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all border border-slate-100 group cursor-pointer" onclick="location.href='/every-week-voca'">
                <div class="card-body items-center text-center p-8">
                <div class="w-16 h-16 bg-indigo-100 text-indigo-600 rounded-full flex items-center justify-center text-3xl mb-4 group-hover:scale-110 transition-transform">
                    📚
                </div>
                <h2 class="card-title text-xl mb-2">Every Week Voca</h2>
                <p class="text-slate-500 text-sm">매주 새롭게 업데이트되는 필수 영단어와 예문을 학습해보세요.</p>
                <div class="card-actions mt-4">
                    <span class="text-indigo-600 font-semibold text-sm">단어장 보기 →</span>
                </div>
                </div>
            </div>

            <!-- Card 2: My English Journey -->
            <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all border border-slate-100 group cursor-pointer" onclick="location.href='/my-english-journey'">
                <div class="card-body items-center text-center p-8">
                <div class="w-16 h-16 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center text-3xl mb-4 group-hover:scale-110 transition-transform">
                    🌱
                </div>
                <h2 class="card-title text-xl mb-2">My English Journey</h2>
                <p class="text-slate-500 text-sm">기초부터 실전까지, 저의 생생한 영어 공부 기록과 팁을 공유합니다.</p>
                <div class="card-actions mt-4">
                    <span class="text-emerald-600 font-semibold text-sm">기록 읽기 →</span>
                </div>
                </div>
            </div>

            <!-- Card 3: About Me / Contact -->
            <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all border border-slate-100 group cursor-pointer" onclick="location.href='/about'">
                <div class="card-body items-center text-center p-8">
                <div class="w-16 h-16 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center text-3xl mb-4 group-hover:scale-110 transition-transform">
                    👋
                </div>
                <h2 class="card-title text-xl mb-2">About Me</h2>
                <p class="text-slate-500 text-sm">이 블로그를 운영하는 이유와 저의 학습 목표가 궁금하신가요?</p>
                <div class="card-actions mt-4">
                    <span class="text-amber-600 font-semibold text-sm">더 알아보기 →</span>
                </div>
                </div>
            </div>
        </section>

        <!-- content -->
        <!-- <main class="max-w-7xl mx-auto p-3">
            <slot />
        </main> -->

        <!-- footer -->
        <footer class="text-center p-10 text-slate-400 text-sm">
            © 2026 Daily Learning English. All rights reserved.
        </footer>
    </body>
</html>