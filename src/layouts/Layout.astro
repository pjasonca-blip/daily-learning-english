---
import '../styles/global.css';
// ThemeToggle 임포트 삭제
const {title} = Astro.props;
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title || 'Daily Learning English'}</title>
        </head>
    <body class="bg-white text-slate-900 min-h-screen">
        <nav class="sticky top-0 z-50 p-6 bg-bg-nav/80 backdrop-blur-md border-b border-border-nav shadow-sm">
            <div class="navbar max-w-7xl mx-auto flex justify-between items-center">
                <a href="/" class="text-xl font-bold bg-linear-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">
                    Daily Learning English
                </a>
                <div class="flex items-center space-x-6 text-sm font-medium">
                    <a href="/" class="hover:text-indigo-600 transition-colors">Home</a>
                    <a href="/every-week-voca" class="hover:text-indigo-600 transition-colors">Every Week Voca</a>
                    <a href="/my-english-journey" class="hover:text-indigo-600 transition-colors">My English Journey</a>
                    <a href="/about" class="hover:text-indigo-600 transition-colors">About</a>
                    <a href="/blog/first-post" class="hover:text-indigo-600 transition-colors">Contact</a>
                    <a href="/contact" class="hover:text-indigo-600 transition-colors">Contact</a>
                </div>
            </div>
        </nav>
        
        <main class="max-w-7xl mx-auto p-4">
            <slot />
        </main>

        <footer class="text-center p-10 text-slate-400 text-sm">
            © 2026 Daily Learning English. All rights reserved.
        </footer>
    </body>
</html>