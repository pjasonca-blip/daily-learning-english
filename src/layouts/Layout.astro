---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
const {title} = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title || 'Daily Learning English'}</title>
		<script is:inline>
			// 1. 초기 테마 설정 (로컬 스토리지 확인)
			const theme = localStorage.getItem('theme') || 'light';
			if (theme === 'dark') document.documentElement.classList.add('dark');
		</script>
	</head>
	<body class="bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-200 min-h-screen">
        <nav class="sticky top-0 z-50 p-6 bg-bg-page/80 backdrop-blur-md border-b border-border-base shadow-sm">
            <div class="max-w-4xl mx-auto flex justify-between items-center">
                <a href="/" class="text-xl font-bold bg-linear-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">
                    Daily English
                </a>
                <div class="flex items-center space-x-6 text-sm font-medium">
                    <a href="/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Home</a>
                    <a href="/blog/first-post" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Latest Post</a>
                    <div class="pl-2 border-l border-border-base">
                        <ThemeToggle />
                    </div>
                </div>
            </div>
        </nav>
		
		<main class="max-w-4xl mx-auto p-6">
			<slot />
		</main>

		<footer class="text-center p-10 text-slate-400 text-sm">
			© 2026 Daily Learning English. All rights reserved.
		</footer>
	</body>
</html>